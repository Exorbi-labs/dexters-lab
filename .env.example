# ─── Dexter's Lab services ─────────────────────────────────────────
# Copy to .env.local and fill in as you go. Everything is optional —
# features degrade honestly when a key is missing.

# AI — either lane works; Claude preferred when both set.
# Force one with DEX_AI_PROVIDER=deepseek | anthropic
# DeepSeek: https://platform.deepseek.com  (OpenAI-compatible, deepseek-v4-flash)
DEEPSEEK_API_KEY=
# Claude: https://platform.claude.com
ANTHROPIC_API_KEY=
# DEX_AI_PROVIDER=
# DEX_ASSIST_MODEL=

# Postgres — phase 1 (replaces localStorage, syncs the team)
# Managed: Neon (https://neon.tech) or Supabase. postgres://user:pass@host:5432/dexterslab
DATABASE_URL=

# Redis — phase 3 (presence, realtime). Upstash (https://upstash.com)
REDIS_URL=

# Google OAuth — phase 1 team sign-in
# https://console.cloud.google.com → Credentials → OAuth client (Web)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_SECRET=

# GitHub — phase 2 (link repos into the codebase)
# https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
